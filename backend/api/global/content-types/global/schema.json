{
    "kind": "singleType",
    "collectionName": "globals",
    "info": {
        "singularName": "global",
        "pluralName": "globals",
        "displayName": "Global Settings",
        "description": "Global site settings including SEO, branding, and organization information"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "siteName": {
            "type": "string",
            "required": true,
            "default": "NADZ Healthcare Dubai"
        },
        "siteUrl": {
            "type": "string",
            "required": true,
            "default": "https://nadzhealthcare.com"
        },
        "canonicalUrl": {
            "type": "string",
            "description": "Optional homepage canonical URL for SEO (full https URL or root-relative path such as /). If empty, defaults to Site URL."
        },
        "siteDescription": {
            "type": "text",
            "required": true
        },
        "defaultSeoTitle": {
            "type": "string"
        },
        "defaultSeoDescription": {
            "type": "text"
        },
        "defaultSeoKeywords": {
            "type": "json"
        },
        "openGraphImage": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": ["images"]
        },
        "twitterHandle": {
            "type": "string"
        },
        "organizationName": {
            "type": "string"
        },
        "organizationLogo": {
            "type": "string"
        },
        "organizationPhone": {
            "type": "string"
        },
        "organizationEmail": {
            "type": "string"
        },
        "socialLinks": {
            "type": "json"
        },
        "themeColor": {
            "type": "string",
            "default": "#165976"
        },
        "robotsConfig": {
            "type": "json"
        },
        "schemaOrgConfig": {
            "type": "json"
        },
        "sitemapConfig": {
            "type": "json"
        },
        "awardsPagePillText": {
            "type": "string",
            "description": "Default pill on Awards & Achievements page when not set on that page (e.g. Recognition)"
        },
        "bookDoctorServices": {
            "type": "json",
            "description": "List of service options for Book Doctor form (array of strings)"
        }
    }
}
