{
  "kind": "collectionType",
  "collectionName": "pages",
  "info": {
    "singularName": "page",
    "pluralName": "pages",
    "displayName": "Page",
    "description": "Generic CMS-driven page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title",
      "required": true
    },
    "seoCanonicalUrl": {
      "type": "string",
      "description": "Canonical URL for SEO (absolute https URL or root-relative path). Prefer this over embedding in metadata JSON. Leave empty for /pages/{slug}."
    },
    "metadata": {
      "type": "json"
    },
    "sections": {
      "type": "dynamiczone",
      "components": [
        "sections.hero",
        "sections.home-care-hero",
        "sections.centered-text",
        "sections.benefits-section",
        "sections.faqs-section",
        "sections.how-it-works-section",
        "sections.services-section",
        "sections.content-section",
        "sections.testimonials-section",
        "sections.quick-links-section"
      ]
    }
  }
}
