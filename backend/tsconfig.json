{
  "extends": "@strapi/typescript-utils/tsconfigs/server",
  "compilerOptions": {
    "noEmit": true,
    "outDir": "."
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.json",
    "config/**/*.ts",
    "config/**/*.js"
  ],
  "exclude": [
    "node_modules/",
    "build/",
    "dist/",
    ".cache/",
    ".tmp/",
    "src/admin/",
    "**/*.test.ts",
    "src/plugins/**"
  ]
}

